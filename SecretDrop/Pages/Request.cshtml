@page "{id?}"
@model RequestModel
@{
    ViewData["Title"] = Model.IsSenderMode ? "Отправка файла" : "Запрос файла";
    // Получаем SiteKey из конфига (предположим, ты передал его через ViewData или Model)
    // Если нет, просто замени строку ниже на свой ключ '0x4AAAAAA...'
    var siteKey = "ТВОЙ_SITE_KEY_ОТ_CLOUDFLARE"; 
}

<!-- Подключаем API Cloudflare с явной отрисовкой -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" 
        nonce="@Html.ViewContext.HttpContext.Items["csp-nonce"]" async defer></script>

<div class="container" style="max-width: 650px;">
    
    <!-- === РЕЖИМ 1: ПОЛУЧАТЕЛЬ (тот, кто ждет файл) === -->
    @if (!Model.IsSenderMode)
    {
        <div id="creator-step-1" class="main-card text-center animate-fade-in">
            <div class="mb-4">
                <div class="d-inline-block p-4 rounded-circle bg-primary bg-opacity-10">
                    <i class="bi bi-broadcast text-primary" style="font-size: 3rem;"></i>
                </div>
            </div>
            <h2 class="fw-bold mb-3">Прием файлов</h2>
            <p class="text-muted mb-4">
                Сгенерируйте одноразовую ссылку-шлюз. Отправьте её собеседнику, 
                и он сможет передать вам файл, текст или фото через защищенный RSA-туннель.
            </p>

            <button onclick="createRequest()" id="btnCreate" class="btn btn-primary btn-lg px-5 py-3 shadow-lg">
                <i class="bi bi-link-45deg me-2"></i>Создать шлюз
            </button>
        </div>

        <div id="creator-step-2" class="main-card text-center d-none animate-fade-in">
            <div class="spinner-grow text-success mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
            <h4 class="mb-3 animate-pulse">Ожидание подключения...</h4>
            
            <div class="input-group mb-3">
                <input type="text" id="requestLink" class="form-control text-center font-monospace text-primary fw-bold" readonly>
                <button class="btn btn-outline-success" onclick="copyLink()">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>

            <div class="d-flex justify-content-center my-4">
                <div class="p-3 bg-white rounded position-relative">
                     <div id="qrcode"></div>
                </div>
            </div>
             <button class="btn btn-sm btn-dark mb-4" onclick="downloadQrImage()">
                <i class="bi bi-download me-2"></i>Скачать QR
            </button>

            <div class="alert alert-info bg-opacity-10 border-0 small">
                <i class="bi bi-info-circle me-2"></i>Не закрывайте эту вкладку. Как только отправитель закончит передачу, файл откроется автоматически.
            </div>
        </div>
    }

    <!-- === РЕЖИМ 2: ОТПРАВИТЕЛЬ (тот, кто перешел по ссылке) === -->
    @if (Model.IsSenderMode)
    {
        <input type="hidden" id="receiverPub" value="@Model.ReceiverPublicKey" />
        <input type="hidden" id="sessionId" value="@Model.SessionId" />

        <div id="sender-ui" class="main-card">
            <div class="text-center mb-4">
                <div class="badge bg-success bg-opacity-10 text-success mb-2 px-3 py-2 rounded-pill">
                    <i class="bi bi-shield-lock-fill me-1"></i> E2E Encrypted Tunnel
                </div>
                <h3>Отправка данных</h3>
            </div>

            <ul class="nav nav-pills nav-fill mb-4">
                <li class="nav-item"><button class="nav-link active" id="tab-file" onclick="switchTab('file')"><i class="bi bi-file-earmark me-2"></i>Файл</button></li>
                <li class="nav-item ms-1"><button class="nav-link" id="tab-text" onclick="switchTab('text')"><i class="bi bi-chat-text me-2"></i>Текст</button></li>
                <li class="nav-item ms-1"><button class="nav-link" id="tab-image" onclick="switchTab('image')"><i class="bi bi-card-image me-2"></i>Фото</button></li>
            </ul>

            <div id="pane-file" class="mb-4">
                <div class="file-drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-cloud-upload display-6 mb-2 text-secondary"></i>
                    <h5 class="fw-normal">Нажмите для выбора</h5>
                    <p id="fileNameDisplay" class="text-muted small mb-0">Файлы до 5 ГБ</p>
                    <input type="file" id="fileInput" class="d-none" onchange="updateFileName(this)">
                </div>
            </div>

            <div id="pane-text" class="mb-4 d-none">
                <textarea id="textInput" class="form-control font-monospace" rows="5" placeholder="Введите секретное сообщение..."></textarea>
            </div>

            <div id="pane-image" class="mb-4 d-none">
                <div class="file-drop-zone" id="imageDropZone" onclick="document.getElementById('imageInput').click()">
                     <div id="imagePreviewPlaceholder">
                        <i class="bi bi-images display-6 mb-2 text-secondary"></i>
                        <p class="mb-0">Нажмите или <b>Ctrl+V</b></p>
                    </div>
                    <img id="imagePreview" class="img-fluid rounded d-none shadow-sm" style="max-height: 250px;" />
                    <input type="file" id="imageInput" class="d-none" accept="image/*" onchange="handleImageSelect(this)">
                </div>
            </div>

            <div class="mb-4 pt-3 border-top border-secondary border-opacity-25">
                 <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="usePassword" onchange="togglePassword(this)">
                    <label class="form-check-label text-muted small fw-bold text-uppercase" for="usePassword">Добавить пароль</label>
                </div>
                <div id="passwordBlock" class="d-none collapse show">
                    <input type="password" id="senderPassword" class="form-control font-monospace" placeholder="Придумайте пароль..." autocomplete="new-password">
                    <small class="text-warning" style="font-size: 0.75rem;">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Передайте пароль получателю через другой канал связи!
                    </small>
                </div>
            </div>

            <button onclick="startReverseUpload()" id="btnSend" class="btn btn-primary w-100 py-3">
                <i class="bi bi-send-fill me-2"></i>Зашифровать и Отправить
            </button>

            <div id="progressArea" class="mt-4 d-none">
                <div class="d-flex justify-content-between small mb-1">
                    <span class="text-muted">Отправка...</span>
                    <span id="progressText" class="text-primary">0%</span>
                </div>
                <div class="progress">
                    <div id="progressBar" class="progress-bar" style="width: 0%"></div>
                </div>
            </div>
        </div>

        <div id="sender-success" class="main-card text-center d-none animate-fade-in">
            <div class="mb-4 text-success">
                <i class="bi bi-check-circle-fill" style="font-size: 5rem;"></i>
            </div>
            <h2 class="fw-bold text-white mb-3">Успешно!</h2>
            <p class="text-muted mb-4">Данные зашифрованы и переданы получателю.<br>Сессия закрыта.</p>
            <a href="/" class="btn btn-outline-light">Отправить что-то еще</a>
        </div>
    }

    <!-- ОБЩЕЕ МОДАЛЬНОЕ ОКНО ДЛЯ КАПЧИ -->
    <div class="modal fade" id="captchaModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary shadow-lg">
                <div class="modal-header border-0 text-center d-block">
                    <h5 class="modal-title text-white">Проверка безопасности</h5>
                    <p class="text-muted small mb-0">Пожалуйста, подтвердите, что вы человек</p>
                </div>
                <div class="modal-body d-flex justify-content-center py-4">
                    <div id="captcha-container"></div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-link text-muted w-100 text-decoration-none" data-bs-dismiss="modal">Отмена</button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.IsCaptchaEnabled)
{
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
            nonce="@Html.ViewContext.HttpContext.Items["csp-nonce"]" async defer></script>
}

<script nonce="@Html.ViewContext.HttpContext.Items["csp-nonce"]">
    const CHUNK_SIZE = 4 * 1024 * 1024;
    let currentMode = 'file';
    let selectedImageBlob = null;
    let privateKeyObj = null;
    let captchaWidgetId = null;
    const siteKey = "@Model.PublickKey";
    const isCaptchaEnabled = @(Model.IsCaptchaEnabled ? "true" : "false");

    // --- ОБЩАЯ ФУНКЦИЯ ВЫЗОВА КАПЧИ ---
    function showCaptcha(onSuccessCallback) {

        if(!isCaptchaEnabled){
            onSuccessCallback(null);
            return;
        }

        const captchaModalEl = document.getElementById('captchaModal');
        const myModal = new bootstrap.Modal(captchaModalEl);
        myModal.show();

        if (captchaWidgetId !== null) {
            turnstile.remove(captchaWidgetId);
        }

        captchaWidgetId = turnstile.render('#captcha-container', {
            sitekey: siteKey,
            callback: function(token) {
                setTimeout(() => {
                    myModal.hide();
                    onSuccessCallback(token);
                }, 500);
            },
        });
    }

    // ==========================================
    // ЛОГИКА ПОЛУЧАТЕЛЯ (CREATOR)
    // ==========================================
    async function createRequest() {
        showCaptcha(executeActualCreate);
    }

    async function executeActualCreate(captchaToken) {
        const btn = document.getElementById('btnCreate');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Генерация ключей...';

        try {
            const keyPair = await window.crypto.subtle.generateKey(
                { name: "RSA-OAEP", modulusLength: 2048, publicExponent: new Uint8Array([1, 0, 1]), hash: "SHA-256" },
                true, ["encrypt", "decrypt"]
            );
            privateKeyObj = keyPair.privateKey; 
            const pubJwk = await window.crypto.subtle.exportKey("jwk", keyPair.publicKey);
            
            const resp = await fetch('?handler=CreateSession', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    publicKey: JSON.stringify(pubJwk),
                    captchaToken: captchaToken 
                })
            });

            if (!resp.ok) throw new Error("Ошибка проверки капчи сервером");

            const { id } = await resp.json();
            document.getElementById('creator-step-1').classList.add('d-none');
            document.getElementById('creator-step-2').classList.remove('d-none');
            const link = `${window.location.origin}/request/${id}`;
            document.getElementById('requestLink').value = link;
            
            new QRCode(document.getElementById("qrcode"), {
                text: link, width: 160, height: 160,
                colorDark : "#000000", colorLight : "#ffffff", correctLevel : QRCode.CorrectLevel.M
            });

            pollStatus(id);
        } catch (e) {
            alert("Ошибка: " + e.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-link-45deg me-2"></i>Создать шлюз';
        }
    }

    async function pollStatus(sessionId) {
        const interval = setInterval(async () => {
            try {
                const resp = await fetch(`?handler=Check&id=${sessionId}`);
                if (resp.status === 200) {
                    clearInterval(interval);
                    const data = await resp.json();
                    finishReceive(data);
                } else if (resp.status === 404) {
                    clearInterval(interval);
                    alert("Сессия истекла или была удалена.");
                    location.reload();
                }
            } catch (e) { console.error(e); }
        }, 2000);
    }

    async function finishReceive(data) {
        document.getElementById('creator-step-2').innerHTML = 
            `<h3 class="mt-5"><span class="spinner-border text-primary"></span> Дешифровка ключа...</h3>`;
        try {
            const encKeyBytes = fromBase64(data.encryptedKey);
            const rawOuterKey = await window.crypto.subtle.decrypt(
                { name: "RSA-OAEP" }, privateKeyObj, encKeyBytes
            );
            const outerKeyObj = await window.crypto.subtle.exportKey("jwk", 
                await window.crypto.subtle.importKey("raw", rawOuterKey, "AES-GCM", true, ["encrypt", "decrypt"])
            );
            window.location.href = `/view/${data.fileId}#${outerKeyObj.k}`;
        } catch (e) {
            alert("Ошибка криптографии: " + e.message);
            location.reload();
        }
    }

    // ==========================================
    // ЛОГИКА ОТПРАВИТЕЛЯ (SENDER)
    // ==========================================
    
    async function startReverseUpload() {
        // Базовая валидация перед вызовом капчи
        if (currentMode === 'file' && !document.getElementById('fileInput').files[0]) { alert("Выберите файл"); return; }
        if (currentMode === 'image' && !selectedImageBlob) { alert("Нет картинки"); return; }
        if (currentMode === 'text' && !document.getElementById('textInput').value) { alert("Введите текст"); return; }
        
        const usePass = document.getElementById('usePassword').checked;
        if (usePass && !document.getElementById('senderPassword').value) { alert("Введите пароль"); return; }

        showCaptcha(executeActualReverseUpload);
    }

    async function executeActualReverseUpload(captchaToken) {
        const btn = document.getElementById('btnSend');
        const progressBar = document.getElementById('progressBar');
        const progressArea = document.getElementById('progressArea');
        
        let blobToSend = null;
        let filename = 'secret';
        let type = 'file';

        if (currentMode === 'file') {
            blobToSend = document.getElementById('fileInput').files[0];
            filename = blobToSend.name;
        } else if (currentMode === 'image') {
            blobToSend = selectedImageBlob;
            filename = "image.png";
            type = 'image';
        } else {
            const txt = document.getElementById('textInput').value;
            blobToSend = new Blob([txt], { type: 'text/plain' });
            filename = 'message.txt';
            type = 'message';
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Шифрование...';
        progressArea.classList.remove('d-none');

        try {
            const fileKey = await window.crypto.subtle.generateKey({ name: "AES-GCM", length: 256 }, true, ["encrypt", "decrypt"]);
            const fileIvBase = window.crypto.getRandomValues(new Uint8Array(12));
            const password = document.getElementById('senderPassword').value;
            const usePass = document.getElementById('usePassword').checked;

            let serverWrappedKey = null;
            let passwordSalt = null;
            let keyToTransport = null;

            if (usePass) {
                const outerKey = await window.crypto.subtle.generateKey({ name: "AES-GCM", length: 256 }, true, ["encrypt", "decrypt"]);
                const salt = window.crypto.getRandomValues(new Uint8Array(16));
                passwordSalt = toBase64(salt);
                const passKey = await deriveKeyFromPassword(password, salt);
                const rawFileKey = await window.crypto.subtle.exportKey("raw", fileKey);
                const innerIv = window.crypto.getRandomValues(new Uint8Array(12));
                const innerEnc = await window.crypto.subtle.encrypt({ name: "AES-GCM", iv: innerIv }, passKey, rawFileKey);
                const innerBlob = new Uint8Array(innerIv.length + innerEnc.byteLength);
                innerBlob.set(innerIv); innerBlob.set(new Uint8Array(innerEnc), 12);
                const outerIv = window.crypto.getRandomValues(new Uint8Array(12));
                const outerEnc = await window.crypto.subtle.encrypt({ name: "AES-GCM", iv: outerIv }, outerKey, innerBlob);
                const fullBlob = new Uint8Array(outerIv.length + outerEnc.byteLength);
                fullBlob.set(outerIv); fullBlob.set(new Uint8Array(outerEnc), 12);
                serverWrappedKey = toBase64(fullBlob);
                keyToTransport = await window.crypto.subtle.exportKey("raw", outerKey);
            } else {
                keyToTransport = await window.crypto.subtle.exportKey("raw", fileKey);
            }

            const metaDataString = JSON.stringify({ filename, size: blobToSend.size, iv: toBase64(fileIvBase), type });

            const initResp = await fetch('/?handler=Init', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    meta: metaDataString,
                    ttl: 60,
                    limit: 2,
                    passwordSalt: passwordSalt,
                    wrappedKey: serverWrappedKey,
                    captchaToken: captchaToken // ПЕРЕДАЕМ ТОКЕН ТУДА
                })
            });
            if (!initResp.ok) throw new Error("Ошибка инициализации (капча?)");
            const { id: fileId } = await initResp.json();

            let offset = 0;
            let chunkIndex = 0;
            while (offset < blobToSend.size) {
                const chunkBlob = blobToSend.slice(offset, offset + CHUNK_SIZE);
                const chunkBuffer = await chunkBlob.arrayBuffer();
                const chunkIv = deriveIv(fileIvBase, chunkIndex);
                const encryptedChunk = await window.crypto.subtle.encrypt({ name: "AES-GCM", iv: chunkIv }, fileKey, chunkBuffer);
                await fetch(`/?handler=Chunk&id=${fileId}`, { method: 'POST', body: encryptedChunk });
                offset += CHUNK_SIZE; chunkIndex++;
                const p = Math.min(100, Math.round((offset / blobToSend.size) * 100));
                progressBar.style.width = p + "%";
                document.getElementById('progressText').innerText = p + "%";
            }

            const receiverPubJson = document.getElementById('receiverPub').value;
            const rsaPubKey = await window.crypto.subtle.importKey("jwk", JSON.parse(receiverPubJson), { name: "RSA-OAEP", hash: "SHA-256" }, false, ["encrypt"]);
            const encryptedTransportKey = await window.crypto.subtle.encrypt({ name: "RSA-OAEP" }, rsaPubKey, keyToTransport);

            const sessionId = document.getElementById('sessionId').value;
            await fetch('?handler=CompleteSession', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    sessionId: sessionId,
                    fileId: fileId,
                    encryptedKey: toBase64(new Uint8Array(encryptedTransportKey)),
                    metaJson: metaDataString
                })
            });

            document.getElementById('sender-ui').classList.add('d-none');
            document.getElementById('sender-success').classList.remove('d-none');

        } catch (e) {
            console.error(e);
            alert("Error: " + e.message);
            btn.disabled = false;
        }
    }

    // --- Helpers (Common) ---
    function switchTab(mode) {
        currentMode = mode;
        ['file', 'text', 'image'].forEach(t => {
            document.getElementById(`tab-${t}`).className = (mode === t) ? 'nav-link active' : 'nav-link';
            const pane = document.getElementById(`pane-${t}`);
            pane.classList.toggle('d-none', mode !== t);
        });
    }

    function togglePassword(chk) {
        const block = document.getElementById('passwordBlock');
        block.classList.toggle('d-none', !chk.checked);
        if(chk.checked) setTimeout(() => document.getElementById('senderPassword').focus(), 50);
        else document.getElementById('senderPassword').value = '';
    }

    function updateFileName(input) {
        if (input.files[0]) {
            const d = document.getElementById('fileNameDisplay');
            d.innerText = input.files[0].name;
            d.classList.add('text-primary', 'fw-bold');
        }
    }

    function handleImageSelect(input) {
        if (input.files && input.files[0]) processImageFile(input.files[0]);
    }

    function processImageFile(file) {
        if (!file.type.startsWith('image/')) { alert("Только изображения!"); return; }
        selectedImageBlob = file;
        const reader = new FileReader();
        reader.onload = (e) => {
            document.getElementById('imagePreviewPlaceholder').classList.add('d-none');
            const img = document.getElementById('imagePreview');
            img.src = e.target.result;
            img.classList.remove('d-none');
        };
        reader.readAsDataURL(file);
    }

    document.addEventListener('paste', function(e) {
        if (currentMode !== 'image') return;
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (let i in items) {
            if (items[i].kind === 'file' && items[i].type.startsWith('image/')) {
                processImageFile(items[i].getAsFile());
                e.preventDefault();
                break;
            }
        }
    });

    function copyLink() {
        const copyText = document.getElementById("requestLink");
        copyText.select();
        navigator.clipboard.writeText(copyText.value);
    }
    
    function downloadQrImage() {
        const c = document.getElementById("qrcode").querySelector("canvas");
        if(c) {
            const a = document.createElement("a");
            a.href = c.toDataURL("image/png");
            a.download = "void-drop-qr.png";
            a.click();
        }
    }
    
    function toBase64(u8) { return btoa(String.fromCharCode.apply(null, u8)); }
    function fromBase64(str) { return Uint8Array.from(atob(str), c => c.charCodeAt(0)); }
    
    function deriveIv(baseIv, counter) {
        const iv = new Uint8Array(baseIv);
        const view = new DataView(iv.buffer);
        const currentLast4 = view.getUint32(8, true);
        view.setUint32(8, currentLast4 ^ counter, true);
        return iv;
    }

    async function deriveKeyFromPassword(password, salt) {
        const enc = new TextEncoder();
        const keyMaterial = await window.crypto.subtle.importKey("raw", enc.encode(password), { name: "PBKDF2" }, false, ["deriveKey"]);
        return await window.crypto.subtle.deriveKey({ name: "PBKDF2", salt: salt, iterations: 100000, hash: "SHA-256" }, keyMaterial, { name: "AES-GCM", length: 256 }, false, ["encrypt", "decrypt"]);
    }
</script>